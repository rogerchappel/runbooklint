{
  "name": "runbooklint",
  "version": "0.1.0",
  "description": "Local-first Markdown runbook linter for safer operational procedures.",
  "type": "module",
  "bin": {
    "runbooklint": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs/POLICY.md",
    "fixtures",
    "scripts",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build --silent && node --test --test-reporter=spec test/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "runbook",
    "markdown",
    "lint",
    "sre",
    "incident-response",
    "devops",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/runbooklint.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/runbooklint/issues"
  },
  "homepage": "https://github.com/rogerchappel/runbooklint#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  }
}
